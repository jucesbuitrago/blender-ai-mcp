# blender-ai-mcp environment example
#
# Copy this file to `.env` and adjust only the values you need.
# Empty values mean "optional / unset".

# ---------------------------------------------------------------------------
# Blender RPC connection
# ---------------------------------------------------------------------------

# Host where the Blender addon RPC server is reachable.
BLENDER_RPC_HOST=127.0.0.1

# Port where the Blender addon RPC server listens.
BLENDER_RPC_PORT=8765

# ---------------------------------------------------------------------------
# Supabase script memory (RAG)
# ---------------------------------------------------------------------------

# Project URL and API key for the `blender_scripts` memory table.
# Leave both empty to disable the buscar_referencias / guardar_script tools.
SUPABASE_URL=
SUPABASE_KEY=

# ---------------------------------------------------------------------------
# Router supervisor
# ---------------------------------------------------------------------------

# Enable the Router Supervisor layer for LLM tool calls.
ROUTER_ENABLED=true

# Log router correction/decision flow in server logs.
ROUTER_LOG_DECISIONS=true

# Enable OpenTelemetry bootstrap.
OTEL_ENABLED=false

# OpenTelemetry exporter: none | console | memory.
OTEL_EXPORTER=none

# OpenTelemetry service name.
OTEL_SERVICE_NAME=blender-ai-mcp

# ---------------------------------------------------------------------------
# MCP surface / runtime
# ---------------------------------------------------------------------------

# Bootstrap surface profile: legacy-manual | legacy-flat | llm-guided |
# internal-debug | code-mode-pilot.
MCP_SURFACE_PROFILE=legacy-flat

# MCP transport mode: stdio | streamable.
MCP_TRANSPORT_MODE=stdio

# Optional contract-line override (for example llm-guided-v2). Leave empty to
# use the surface default.
MCP_DEFAULT_CONTRACT_LINE=

# Default list page size used by MCP list/search style responses.
MCP_LIST_PAGE_SIZE=100

# Foreground MCP tool timeout in seconds.
MCP_TOOL_TIMEOUT_SECONDS=30.0

# Background MCP task timeout in seconds.
MCP_TASK_TIMEOUT_SECONDS=300.0

# RPC socket timeout in seconds.
RPC_TIMEOUT_SECONDS=30.0

# Blender addon execution timeout in seconds.
ADDON_EXECUTION_TIMEOUT_SECONDS=30.0

# Host for stateful Streamable HTTP MCP mode.
MCP_HTTP_HOST=127.0.0.1

# Port for stateful Streamable HTTP MCP mode.
MCP_HTTP_PORT=8000

# HTTP path for the Streamable HTTP MCP endpoint.
MCP_STREAMABLE_HTTP_PATH=/mcp

# Expose native prompt assets as tool-compatible list_prompts/get_prompt bridge
# tools. Keep true for tool-only clients; set false for prompt-capable
# Streamable HTTP clients that should use native MCP prompts directly.
MCP_PROMPTS_AS_TOOLS_ENABLED=true

# Guided naming policy mode: warn | block_opaque_role_sensitive.
MCP_GUIDED_NAMING_POLICY_MODE=warn

# ---------------------------------------------------------------------------
# Vision runtime
# ---------------------------------------------------------------------------

# Enable the bounded vision-assist runtime.
VISION_ENABLED=false

# Vision backend provider: transformers_local | mlx_local |
# openai_compatible_external.
VISION_PROVIDER=transformers_local

# Allow vision assistance on the llm-guided surface.
VISION_ALLOW_ON_GUIDED=true

# Maximum images per bounded vision request.
VISION_MAX_IMAGES=8

# Maximum output tokens for one vision request.
VISION_MAX_TOKENS=400

# Vision request timeout in seconds.
VISION_TIMEOUT_SECONDS=20.0

# Local Hugging Face vision model ID.
VISION_LOCAL_MODEL_ID=

# Local Hugging Face vision model path override.
VISION_LOCAL_MODEL_PATH=

# Device for local Hugging Face vision backend.
VISION_LOCAL_DEVICE=cpu

# Dtype for local Hugging Face vision backend.
VISION_LOCAL_DTYPE=auto

# Local MLX vision model ID.
VISION_MLX_MODEL_ID=

# Local MLX vision model path override.
VISION_MLX_MODEL_PATH=

# Generic external OpenAI-compatible base URL.
VISION_EXTERNAL_BASE_URL=

# Generic external OpenAI-compatible model name.
VISION_EXTERNAL_MODEL=

# Inline API key for the generic external vision endpoint.
VISION_EXTERNAL_API_KEY=

# Environment variable name that contains the generic external API key.
VISION_EXTERNAL_API_KEY_ENV=

# External provider profile: generic | openrouter | google_ai_studio.
VISION_EXTERNAL_PROVIDER=generic

# Optional external vision contract-profile override:
# generic_full | google_family_compare
# Leave empty to use runtime auto-match / provider defaults.
VISION_EXTERNAL_CONTRACT_PROFILE=

# Optional OpenRouter base URL override.
VISION_OPENROUTER_BASE_URL=

# OpenRouter multimodal model ID.
VISION_OPENROUTER_MODEL=

# Inline OpenRouter API key.
VISION_OPENROUTER_API_KEY=

# Environment variable name that contains the OpenRouter API key.
VISION_OPENROUTER_API_KEY_ENV=

# Optional site/referrer URL sent to OpenRouter.
VISION_OPENROUTER_SITE_URL=

# Optional site/title sent to OpenRouter.
VISION_OPENROUTER_SITE_NAME=

# Require OpenRouter to route only through providers that support the requested
# parameters. Default: false. Turn this on when you want stricter provider
# filtering and are willing to trade compatibility for exact parameter support.
VISION_OPENROUTER_REQUIRE_PARAMETERS=false

# Enable OpenRouter response-healing plugin for bounded JSON compare paths.
# Default: true.
VISION_OPENROUTER_ENABLE_RESPONSE_HEALING=true

# For Qwen-family OpenRouter models, prefer `response_format=json_object`
# instead of `json_schema`, following the current official Qwen JSON-mode
# guidance. Default: true.
VISION_OPENROUTER_PREFER_JSON_OBJECT_FOR_QWEN=true

# Optional Google AI Studio base URL override.
VISION_GEMINI_BASE_URL=

# Google AI Studio / Gemini model ID.
VISION_GEMINI_MODEL=

# Inline Google AI Studio / Gemini API key.
VISION_GEMINI_API_KEY=

# Environment variable name that contains the Google AI Studio / Gemini API key.
VISION_GEMINI_API_KEY_ENV=

# ---------------------------------------------------------------------------
# Optional segmentation sidecar
# ---------------------------------------------------------------------------

# Enable the advisory part-segmentation sidecar.
VISION_SEGMENTATION_ENABLED=false

# Segmentation sidecar provider profile.
VISION_SEGMENTATION_PROVIDER=generic_sidecar

# Base URL / endpoint for the optional segmentation sidecar.
VISION_SEGMENTATION_ENDPOINT=

# Optional model identifier for the segmentation sidecar.
VISION_SEGMENTATION_MODEL=

# Inline API key for the segmentation sidecar.
VISION_SEGMENTATION_API_KEY=

# Environment variable name that contains the segmentation sidecar API key.
VISION_SEGMENTATION_API_KEY_ENV=

# Segmentation sidecar timeout in seconds.
VISION_SEGMENTATION_TIMEOUT_SECONDS=15.0

# Maximum accepted part outputs from the segmentation sidecar.
VISION_SEGMENTATION_MAX_PARTS=16
